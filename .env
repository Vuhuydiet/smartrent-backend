# SmartRent Backend Environment Configuration
# Default values for development

# Application Configuration
SPRING_PROFILES_ACTIVE=docker
APP_PORT=8080

# Database Configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=smartrent
MYSQL_USER=smartrent_user
MYSQL_PASSWORD=smartrent_pass
DB_USERNAME=root
DB_PASSWORD=root
IDENTITY_SERVICE_DB_URL=jdbc:mysql://mysql:3306/smartrent
MYSQL_PORT=3306

# Redis Configuration
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
REDIS_PORT=6379

# Development Tools
PHPMYADMIN_PORT=8081
REDIS_COMMANDER_PORT=8082
MYSQL_DEV_PORT=3307
REDIS_DEV_PORT=6380

# Security Settings
JWT_SECRET=dev-jwt-secret-change-in-production
ENCRYPTION_KEY=dev-encryption-key-change-in-production

# Logging
LOG_LEVEL=INFO
ROOT_LOG_LEVEL=WARN

# Health Checks
MYSQL_HEALTH_CHECK_INTERVAL=30
REDIS_HEALTH_CHECK_INTERVAL=30
APP_HEALTH_CHECK_INTERVAL=30
MYSQL_HEALTH_CHECK_TIMEOUT=20
REDIS_HEALTH_CHECK_TIMEOUT=3
APP_HEALTH_CHECK_TIMEOUT=10
MYSQL_HEALTH_CHECK_RETRIES=10
REDIS_HEALTH_CHECK_RETRIES=3
APP_HEALTH_CHECK_RETRIES=3

# Performance
JAVA_OPTS=-Xms512m -Xmx1024m
DB_MAX_POOL_SIZE=20
DB_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000
REDIS_MAX_ACTIVE=8
REDIS_MAX_IDLE=8
REDIS_MIN_IDLE=0
REDIS_TIMEOUT=2000
