# SmartRent Backend Environment Configuration
# Copy this file to .env and modify the values as needed

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Spring Boot Profile (docker, local, prod)
SPRING_PROFILES_ACTIVE=docker

# Application Port
APP_PORT=8080

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# MySQL Database Settings
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=smartrent
MYSQL_USER=smartrent_user
MYSQL_PASSWORD=smartrent_pass

# Database Connection (used by Spring Boot app)
DB_USERNAME=root
DB_PASSWORD=root
IDENTITY_SERVICE_DB_URL=jdbc:mysql://mysql:3306/smartrent

# MySQL Port (external access)
MYSQL_PORT=3306

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis Settings
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
REDIS_PORT=6379

# =============================================================================
# DEVELOPMENT TOOLS (for docker-compose.dev.yml)
# =============================================================================

# phpMyAdmin Port
PHPMYADMIN_PORT=8081

# Redis Commander Port
REDIS_COMMANDER_PORT=8082

# Development MySQL Port (to avoid conflicts)
MYSQL_DEV_PORT=3307

# Development Redis Port (to avoid conflicts)
REDIS_DEV_PORT=6380

# =============================================================================
# SECURITY SETTINGS (for production)
# =============================================================================

# JWT Secret (generate a strong secret for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Encryption Key (generate a strong key for production)
ENCRYPTION_KEY=your-encryption-key-change-this-in-production

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Root Log Level
ROOT_LOG_LEVEL=WARN

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================

# Health check intervals (in seconds)
MYSQL_HEALTH_CHECK_INTERVAL=30
REDIS_HEALTH_CHECK_INTERVAL=30
APP_HEALTH_CHECK_INTERVAL=30

# Health check timeouts (in seconds)
MYSQL_HEALTH_CHECK_TIMEOUT=20
REDIS_HEALTH_CHECK_TIMEOUT=3
APP_HEALTH_CHECK_TIMEOUT=10

# Health check retries
MYSQL_HEALTH_CHECK_RETRIES=10
REDIS_HEALTH_CHECK_RETRIES=3
APP_HEALTH_CHECK_RETRIES=3

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# JVM Memory Settings
JAVA_OPTS=-Xms512m -Xmx1024m

# Database Connection Pool
DB_MAX_POOL_SIZE=20
DB_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# Redis Connection Pool
REDIS_MAX_ACTIVE=8
REDIS_MAX_IDLE=8
REDIS_MIN_IDLE=0
REDIS_TIMEOUT=2000
