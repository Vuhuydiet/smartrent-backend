BREVO_API_KEY=your-brevo-api-key
SENDER_EMAIL=your-email@gmail.com
SENDER_NAME=SmartRent
CLIENT_ID=your-google-client-id
CLIENT_SECRET=your-google-client-secret

# Database Configuration
IDENTITY_SERVICE_DB_URL=jdbc:mysql://localhost:3306/smartrent?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your-password

# Redis Configuration
REDIS_USERNAME=
REDIS_PWD=
REDIS_HOST=localhost
CACHE_TYPE=redis

# JWT Configuration
ACCESS_SIGNER_KEY=your-access-signer-key-min-512-bits
REFRESH_SIGNER_KEY=your-refresh-signer-key-min-512-bits
RESET_PASSWORD_SIGNER_KEY=your-reset-password-signer-key-min-512-bits
VALID_DURATION=3600
REFRESHABLE_DURATION=86400
RESET_PASSWORD_DURATION=900

# Google Auth Configuration
GOOGLE_AUTH_CLIENT_REDIRECT_URI=http://localhost:3000/auth/callback/google

# Cloudflare R2 Storage Configuration
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=smart-rent
# Phase 1: R2 public dev URL, Phase 2: https://cdn.smartrent.io.vn
R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev
R2_MAX_IMAGE_SIZE_MB=10
R2_MAX_VIDEO_SIZE_MB=100
R2_UPLOAD_URL_TTL_MINUTES=10
R2_DOWNLOAD_URL_TTL_MINUTES=60

# SePay Configuration (VietQR + IPN webhook)
# Merchant ID + Secret Key from the SePay dashboard (my.sepay.vn).
# SePay sends the Secret Key back in the IPN's "Authorization: Apikey <secret>" header.
SEPAY_MERCHANT_ID=YOUR_SEPAY_MERCHANT_ID
SEPAY_SECRET_KEY=YOUR_SEPAY_SECRET_KEY
SEPAY_ACCOUNT_NUMBER=YOUR_BANK_ACCOUNT_NUMBER
SEPAY_BANK_CODE=MBBank
SEPAY_ACCOUNT_NAME=YOUR_ACCOUNT_NAME
SEPAY_IPN_URL=http://localhost:8080/v1/payments/webhook/sepay

# Twilio SMS OTP Configuration
TWILIO_OTP_ENABLED=false
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+10000000000

# Client URL
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000/admin
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Admin Contact Configuration
ADMIN_CONTACT_PHONE=0123456789
